{
  "name": "truxify-backend-api",
  "version": "1.0.0",
  "description": "Truxify Backend API - Node.js, Express, WebSockets",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "check-env": "node scripts/check-env.js",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --max-warnings=0",
    "verify-db": "node scripts/verify-db-schema.js",
    "seed:dev": "node scripts/seed-dev-profile.js"
  },
  "dependencies": {
    "@sentry/node": "^10.62.0",
    "@supabase/supabase-js": "^2.109.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "ethers": "6.17.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "firebase-admin": "^14.1.0",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.0",
    "mongodb": "^7.4.0",
    "mongoose": "^9.7.3",
    "multer": "^2.2.0",
    "opossum": "^10.0.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "rate-limit-redis": "^5.0.0",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "overrides": {
    "uuid": "^11.1.1",
    "protobufjs": "^7.5.4"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.9",
    "globals": "^17.7.0",
    "nodemon": "^3.1.2",
    "supertest": "^7.2.2",
    "vitest": "^4.1.9"
  },
  "keywords": [
    "express",
    "websockets",
    "supabase",
    "mongodb",
    "redis",
    "firebase"
  ],
  "author": "Truxify Dev Team",
  "license": "ISC"
}
